{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "folioblocks/filmstrip-gallery-block",
	"version": "1.2",
	"title": "Filmstrip Gallery",
	"category": "folioblocks",
	"allowedBlocks": [
		"folioblocks/pb-image-block"
	],
